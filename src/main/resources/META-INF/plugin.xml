<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>dev.jarviis.obsidian.obsidian-lens</id>
    <name>Obsidian Lens</name>
    <vendor url="https://github.com/jarviis">Jarviis</vendor>

    <description><![CDATA[
        Bring your Obsidian vault into JetBrains IDEs. View, navigate, and link your notes without leaving the editor.<br/>
        <br/>
        <b>Features</b>
        <ul>
            <li><b>Wiki-link rendering</b> — <code>[[Note|Alias]]</code> folds inline to its display name; click to open, Cmd+Click to edit</li>
            <li><b>Wiki-link autocompletion</b> — type <code>[[</code> to get note name suggestions from the active vault</li>
            <li><b>Backlinks panel</b> — shows outgoing links (this note → others) and incoming backlinks (others → this note)</li>
            <li><b>Graph view</b> — interactive force-directed graph of all vault notes and their wiki-link connections; zoom, pan, drag nodes</li>
            <li><b>Code ↔ Notes bridge</b> — gutter icons on <code>TODO/FIXME: [[Note]]</code> comments link directly to vault notes</li>
            <li><b>Open in Obsidian</b> — jump from any note to the Obsidian app in one click</li>
            <li><b>Per-project vault</b> — each project is linked to exactly one vault; auto-detected on first open, configurable via Settings</li>
        </ul>
        <br/>
        Works with IntelliJ IDEA, WebStorm, PyCharm, CLion, GoLand, PhpStorm, Rider, RubyMine, and Android Studio.<br/>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.ObsidianBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ==================== Startup ==================== -->
        <postStartupActivity implementation="dev.jarviis.obsidian.startup.ObsidianStartupActivity"/>

        <!-- ==================== Services ==================== -->
        <applicationService
            serviceInterface="dev.jarviis.obsidian.settings.AppVaultSettings"
            serviceImplementation="dev.jarviis.obsidian.settings.AppVaultSettings"/>

        <applicationService
            serviceInterface="dev.jarviis.obsidian.vault.VaultManager"
            serviceImplementation="dev.jarviis.obsidian.vault.VaultManager"/>

        <projectService
            serviceInterface="dev.jarviis.obsidian.settings.ProjectVaultSettings"
            serviceImplementation="dev.jarviis.obsidian.settings.ProjectVaultSettings"/>

        <!-- ==================== PSI / References ==================== -->
        <psi.referenceContributor
            language="Markdown"
            implementation="dev.jarviis.obsidian.psi.WikiLinkReferenceContributor"/>

        <completion.contributor
            language="Markdown"
            implementationClass="dev.jarviis.obsidian.psi.WikiLinkCompletionContributor"
            order="first"/>

        <lang.foldingBuilder
            language="Markdown"
            implementationClass="dev.jarviis.obsidian.psi.WikiLinkFoldingBuilder"/>


        <editorFactoryListener
            implementation="dev.jarviis.obsidian.psi.WikiLinkEditorFactoryListener"/>

        <!-- ==================== Tool Windows ==================== -->
        <toolWindow
            id="Obsidian Backlinks"
            anchor="right"
            secondary="true"
            doNotActivateOnStart="true"
            factoryClass="dev.jarviis.obsidian.toolwindow.backlinks.BacklinksToolWindowFactory"
            icon="dev.jarviis.obsidian.ObsidianIcons.ToolWindow"/>


        <toolWindow
            id="Obsidian Graph"
            anchor="right"
            secondary="true"
            doNotActivateOnStart="true"
            factoryClass="dev.jarviis.obsidian.toolwindow.graph.GraphToolWindowFactory"
            icon="dev.jarviis.obsidian.ObsidianIcons.ToolWindow"/>

        <!-- ==================== Editor / Line Markers ==================== -->
        <lineMarkerProvider
            language="JAVA"
            implementationClass="dev.jarviis.obsidian.bridge.TodoBridgeLineMarkerProvider"/>
        <lineMarkerProvider
            language="kotlin"
            implementationClass="dev.jarviis.obsidian.bridge.TodoBridgeLineMarkerProvider"/>
        <lineMarkerProvider
            language="Python"
            implementationClass="dev.jarviis.obsidian.bridge.TodoBridgeLineMarkerProvider"/>
        <lineMarkerProvider
            language="JavaScript"
            implementationClass="dev.jarviis.obsidian.bridge.TodoBridgeLineMarkerProvider"/>
        <lineMarkerProvider
            language="TypeScript"
            implementationClass="dev.jarviis.obsidian.bridge.TodoBridgeLineMarkerProvider"/>
        <lineMarkerProvider
            language="go"
            implementationClass="dev.jarviis.obsidian.bridge.TodoBridgeLineMarkerProvider"/>

        <!-- ==================== Settings ==================== -->
        <projectConfigurable
            parentId="tools"
            id="dev.jarviis.obsidian.settings.ProjectSettingsConfigurable"
            displayName="Obsidian Lens"
            instance="dev.jarviis.obsidian.settings.ProjectSettingsConfigurable"/>

    </extensions>

    <actions>
        <group id="ObsidianBridge.ActionGroup" text="Obsidian" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action
                id="ObsidianBridge.OpenInObsidian"
                class="dev.jarviis.obsidian.actions.OpenInObsidianAction"
                text="Open in Obsidian"
                description="Open the current note in the Obsidian application"/>
        </group>
    </actions>

</idea-plugin>
